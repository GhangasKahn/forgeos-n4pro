# Example standalone composition for ForgeOS.
# On OpenNept4une, keep its model-specific printer.cfg and user_settings.cfg;
# deploy only the overlays, then add the single forge_phase1 include below.

[include forgeos/printer_n4pro.cfg]
[include forgeos/forge_phase1.cfg]

# Keep Mainsail client macros if present
# [include mainsail.cfg]

[include user_settings.cfg]
